# pkgIndex.tcl.in -- generated by ./configure or build-win.bat
#
# Release layout (all files in same directory):
#   pkgIndex.tcl
#   tclmcairo-@PACKAGE_VERSION@.tm    TclOO wrapper + loader
#   libtclmcairo.so / .dylib / .dll   C extension

if {![package vsatisfies [package provide Tcl] 8.6-]} { return }

package ifneeded @PACKAGE_NAME@ @PACKAGE_VERSION@ \
    [list source [file join $dir @PACKAGE_NAME@-@PACKAGE_VERSION@.tm]]
