# pkgIndex.tcl -- generated from pkgIndex.tcl.in
# Files in $dir: libtclmcairo.so/.dll, tclmcairo-@PACKAGE_VERSION@.tm,
#                canvas2cairo-0.1.tm, shape_renderer-0.1.tm, svg2cairo-0.1.tm

if {![package vsatisfies [package provide Tcl] 8.6-]} { return }

# Load the C extension directly, then source the OO wrapper
package ifneeded @PACKAGE_NAME@ @PACKAGE_VERSION@ [list apply {{dir ver} {
    if {$::tcl_platform(platform) eq "windows"} {
        # Pre-load Cairo dependencies with absolute paths
        # so Windows finds them before loading tclmcairo.dll
        # DLL-Verzeichnis zum PATH hinzufügen damit Windows
        # Abhängigkeiten (liblunasvg.dll etc.) findet
        set _oldpath $::env(PATH)
        set ::env(PATH) "$dir;$_oldpath"

        foreach dep {
            libbz2-1.dll
            zlib1.dll
            libpng16-16.dll
            libexpat-1.dll
            libpcre2-8-0.dll
            libiconv-2.dll
            libintl-8.dll
            libglib-2.0-0.dll
            libgraphite2.dll
            libharfbuzz-0.dll
            libbrotlicommon.dll
            libbrotlidec.dll
            libfreetype-6.dll
            libfontconfig-1.dll
            libpixman-1-0.dll
            libcairo-2.dll
            libgcc_s_seh-1.dll
            libwinpthread-1.dll
            libstdc++-6.dll
            libplutovg.dll
            liblunasvg.dll
            lunasvg.dll
        } {
            set p [file join $dir $dep]
            if {[file exists $p]} { catch {load $p} }
        }
        load [file join $dir tclmcairo.dll]
        set ::env(PATH) $_oldpath
    } else {
        load [file join $dir libtclmcairo.so]
    }
    source [file join $dir tclmcairo-${ver}.tm]
}} $dir @PACKAGE_VERSION@]

package ifneeded canvas2cairo 0.1 \
    [list source [file join $dir canvas2cairo-0.1.tm]]

package ifneeded shape_renderer 0.1 \
    [list source [file join $dir shape_renderer-0.1.tm]]

package ifneeded svg2cairo 0.1 \
    [list source [file join $dir svg2cairo-0.1.tm]]
